<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if title !== site.title %} — {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Anti-FOUC: apply stored theme before paint -->
  <script>(function(){var t=localStorage.getItem('esb-theme');if(t&&t!=='system')document.documentElement.setAttribute('data-theme',t)})()</script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="{{ og_type or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:locale" content="{{ site.locale }}">
  <meta property="og:site_name" content="{{ site.title }}">

  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/assets/css/tracker-base.css">
  {% if extra_css %}<link rel="stylesheet" href="{{ extra_css }}">{% endif %}
</head>
<body>
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-logo">{{ site.title }}</a>
      <div class="nav-actions">
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Sjálfvirkt" title="Sjálfvirkt">&#x25D0;</button>
        <button class="nav-toggle" type="button" aria-label="Valmynd" aria-expanded="false">
          <span class="nav-hamburger"></span>
        </button>
      </div>
      <ul class="nav-links">
        <li><a href="/fullyrdingar/"{% if page.url == "/fullyrdingar/" %} aria-current="page"{% endif %}>Fullyrðingar</a></li>
        <li><a href="/umraedan/"{% if "/umraedan/" in page.url %} aria-current="page"{% endif %}>Umræðan</a></li>
        <li><a href="/raddirnar/"{% if "/raddirnar/" in page.url %} aria-current="page"{% endif %}>Raddirnar</a></li>
        <li><a href="/heimildir/"{% if "/heimildir/" in page.url %} aria-current="page"{% endif %}>Heimildir</a></li>
        <li><a href="/thingraedur/"{% if "/thingraedur/" in page.url %} aria-current="page"{% endif %}>Þingræður</a></li>
        <li><a href="/adferdarfraedi/"{% if page.url == "/adferdarfraedi/" %} aria-current="page"{% endif %}>Aðferðafræði</a></li>
        <li><a href="/um-okkur/"{% if page.url == "/um-okkur/" %} aria-current="page"{% endif %}>Um okkur</a></li>
      </ul>
    </nav>
  </header>

  <main class="site-main{% if wide_layout %} site-main--wide{% endif %}">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>{{ site.title }} — óháð upplýsingaverkefni um ESB-þjóðaratkvæðagreiðsluna {{ site.referendum_date | isDate }}.</p>
    <p>Greiningum er safnað og þær unnar með aðstoð spjallmennisins Claude. Umsjón: Brynjólfur Gauti Guðrúnar Jónsson.</p>
    <p class="footer-links">
      <a href="/um-okkur/">Um okkur</a> &middot;
      <a href="/adferdarfraedi/">Aðferðafræði</a> &middot;
      <a href="mailto:greining@esbvaktin.is">Senda grein</a>
    </p>
  </footer>

  <script src="/assets/js/theme-toggle.js" defer></script>
  <script src="/assets/js/mobile-nav.js" defer></script>
  <script src="/assets/js/evidence-preview.js" defer></script>
  {% if extra_js %}<script src="/assets/js/site-taxonomy.js" defer></script>{% endif %}
  {% if extra_js %}<script src="/assets/js/tracker-utils.js" defer></script>{% endif %}
  {% if extra_js %}<script src="/assets/js/tracker-renderer.js" defer></script>{% endif %}
  {% if extra_js %}<script src="/assets/js/tracker-controller.js" defer></script>{% endif %}
  {% if extra_js %}<script src="{{ extra_js }}" defer{% if extra_js_data %} {{ extra_js_data | safe }}{% endif %}></script>{% endif %}
</body>
</html>
