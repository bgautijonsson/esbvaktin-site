---
layout: base.njk
wide_layout: true
---

{% set linkedReports = linked_reports | resolveContent("reports") %}
{% set linkedClaims = linked_claims | resolveContent("claims") %}
{% set linkedEntities = linked_entities | resolveContent("entities") %}
{% set linkedEvidence = linked_evidence | resolveContent("evidence") %}
{% set linkedDebates = linked_debates | resolveContent("debates") %}

<article class="briefing-page">
  <nav class="report-nav" aria-label="Til baka">
    <a href="/vikuyfirlit/" class="report-back">&larr; Til baka í vikuyfirlit</a>
  </nav>

  <header class="briefing-header">
    <div class="briefing-kicker-row">
      <span class="briefing-kicker">Vikuyfirlit</span>
      <span class="briefing-status">Yfirfarið fyrir birtingu</span>
    </div>
    <h1>{{ title }}</h1>
    <p class="briefing-date-range">{{ week_start | isDateRange(week_end) }}</p>
    <p class="briefing-summary">{{ summary_deck }}</p>
  </header>

  {% if key_takeaways and key_takeaways | length %}
  <section class="briefing-section">
    <div class="briefing-section-head">
      <p class="home-section-label">Í stuttu máli</p>
      <h2>Það sem skiptir mestu máli í þessari viku</h2>
    </div>
    <ul class="briefing-takeaways">
      {% for takeaway in key_takeaways %}
      <li>{{ takeaway }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <section class="briefing-snapshot-grid">
    <div class="briefing-snapshot-card">
      <p class="home-section-label">Hvað breyttist</p>
      <h2>Framvindan í umræðunni</h2>
      <p>{{ what_changed }}</p>
    </div>
    <div class="briefing-snapshot-card">
      <p class="home-section-label">Fullyrðingar</p>
      <h2>Hvað var mest deilt um</h2>
      <p>{{ claims_snapshot }}</p>
    </div>
    <div class="briefing-snapshot-card">
      <p class="home-section-label">Þingið</p>
      <h2>Hvað gerðist á Alþingi</h2>
      <p>{{ althingi_snapshot }}</p>
    </div>
    <div class="briefing-snapshot-card">
      <p class="home-section-label">Raddirnar</p>
      <h2>Hverjir mótuðu tóninn</h2>
      <p>{{ entities_snapshot }}</p>
    </div>
  </section>

  <section class="briefing-section">
    <div class="briefing-section-head">
      <p class="home-section-label">Fylgstu með næst</p>
      <h2>Settu vikuna í stærra samhengi</h2>
    </div>
    <p class="briefing-copy">
      Vikuyfirlitið á að hjálpa þér að sjá hvað breyttist. Til að meta hvort umræðan sé að skýrast eða harðna er næsta skref að bera saman nýju þróunina við málaflokkana á <a href="/malefni/">Málefni</a> og fara svo í fullyrðingar, greiningar eða heimildir eftir þörfum.
    </p>
  </section>

  {% if content | trim %}
  <section class="briefing-section briefing-section--body">
    {{ content | safe }}
  </section>
  {% endif %}

  <section class="briefing-section">
    <div class="briefing-section-head">
      <p class="home-section-label">Tengd gögn</p>
      <h2>Opnaðu undirliggjandi efni beint úr samantektinni</h2>
    </div>

    {% if linkedReports | length %}
    <div class="content-link-group">
      <h3>Greiningar</h3>
      <div class="content-card-grid">
        {% for item in linkedReports %}
        <a href="{{ item.url }}" class="content-card">
          <span class="content-card-eyebrow">{{ item.eyebrow }}</span>
          <h4>{{ item.title }}</h4>
          {% if item.meta | length %}<p class="content-card-meta">{{ item.meta | join(" · ") }}</p>{% endif %}
          <p>{{ item.text }}</p>
          {% if item.stats %}<span class="content-card-stat">{{ item.stats }}</span>{% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if linkedClaims | length %}
    <div class="content-link-group">
      <h3>Fullyrðingar</h3>
      <div class="content-card-grid">
        {% for item in linkedClaims %}
        <a href="{{ item.url }}" class="content-card">
          <span class="content-card-eyebrow">{{ item.eyebrow }}</span>
          <h4>{{ item.title }}</h4>
          {% if item.meta | length %}<p class="content-card-meta">{{ item.meta | join(" · ") }}</p>{% endif %}
          <p>{{ item.text }}</p>
          {% if item.stats %}<span class="content-card-stat">{{ item.stats }}</span>{% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if linkedEntities | length %}
    <div class="content-link-group">
      <h3>Raddir í umræðunni</h3>
      <div class="content-card-grid">
        {% for item in linkedEntities %}
        <a href="{{ item.url }}" class="content-card">
          <span class="content-card-eyebrow">{{ item.eyebrow }}</span>
          <h4>{{ item.title }}</h4>
          {% if item.meta | length %}<p class="content-card-meta">{{ item.meta | join(" · ") }}</p>{% endif %}
          <p>{{ item.text }}</p>
          {% if item.stats %}<span class="content-card-stat">{{ item.stats }}</span>{% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if linkedEvidence | length %}
    <div class="content-link-group">
      <h3>Heimildir</h3>
      <div class="content-card-grid">
        {% for item in linkedEvidence %}
        <a href="{{ item.url }}" class="content-card">
          <span class="content-card-eyebrow">{{ item.eyebrow }}</span>
          <h4>{{ item.title }}</h4>
          {% if item.meta | length %}<p class="content-card-meta">{{ item.meta | join(" · ") }}</p>{% endif %}
          <p>{{ item.text }}</p>
          {% if item.stats %}<span class="content-card-stat">{{ item.stats }}</span>{% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if linkedDebates | length %}
    <div class="content-link-group">
      <h3>Þingræður</h3>
      <div class="content-card-grid">
        {% for item in linkedDebates %}
        <a href="{{ item.url }}" class="content-card">
          <span class="content-card-eyebrow">{{ item.eyebrow }}</span>
          <h4>{{ item.title }}</h4>
          {% if item.meta | length %}<p class="content-card-meta">{{ item.meta | join(" · ") }}</p>{% endif %}
          <p>{{ item.text }}</p>
          {% if item.stats %}<span class="content-card-stat">{{ item.stats }}</span>{% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </section>

  <footer class="briefing-footer">
    <p>{{ method_note }}</p>
  </footer>
</article>
