---
layout: base.njk
extra_css: /assets/css/entity-detail.css
return_link_support: true
evidence_preview: true
---

{# ── Stance label from score ── #}
{% if entity.stance_score >= 0.5 %}
  {% set stanceLabel = "ESB-jákvæð" %}
{% elif entity.stance_score <= -0.5 %}
  {% set stanceLabel = "ESB-gagnrýnin" %}
{% elif entity.stance_score is number and entity.stance_score > -0.1 and entity.stance_score < 0.1 %}
  {% set stanceLabel = "Hlutlaus" %}
{% else %}
  {% set stanceLabel = "Blandað" %}
{% endif %}

{# ── Compute stance hue/sat for CSS ── #}
{% set score = entity.stance_score or 0 %}
{% if score >= 0 %}
  {% set stanceHue = 60 + score * 150 %}
{% else %}
  {% set stanceHue = 60 + score * 60 %}
{% endif %}
{% set stanceSat = 10 + (score if score >= 0 else -score) * 60 %}
{% set dotLeft = ((score + 1) / 2 * 100) %}

{# ── Total claims (all attributions) ── #}
{% set totalClaims = entity.claims | length %}

{# ── Scorecard total (active attributions only) ── #}
{% set scorecardTotal = 0 %}
{% for v, count in entity.scorecard %}
  {% set scorecardTotal = scorecardTotal + count %}
{% endfor %}

<article class="ed-entity" style="--stance-hue: {{ stanceHue }}; --stance-sat: {{ stanceSat }}%">
  {# ── Back link ── #}
  <a href="/raddirnar/" class="ed-back" data-return-link data-return-fallback="/raddirnar/" data-return-label="← Til baka í fyrri niðurstöður">&larr; Til baka á Raddirnar</a>

  {# ── Header ── #}
  <header class="ed-header">
    <div class="ed-header-top">
      <h1 class="ed-name">{{ entity.name }}</h1>
      <span class="et-type-badge et-type-{{ entity.type }}">{% if entity.subtype == "media" %}Fjölmiðill{% elif entity.subtype == "politician" %}Stjórnmálafólk{% else %}{{ entity.type | entityTypeLabel }}{% endif %}</span>
    </div>

    {% if entity.role %}
      <p class="ed-role">
        {{ entity.role | capitalize }}{% if entity.party and entity.party_slug %} (<a href="/raddirnar/{{ entity.party_slug }}/">{{ entity.party }}</a>){% elif entity.party %} ({{ entity.party }}){% endif %}
      </p>
    {% endif %}

    {% if entity.description %}
      <p class="ed-description">{{ entity.description }}</p>
    {% endif %}
  </header>

  {# ── Stats row ── #}
  <div class="ed-stats">
    {# Stance indicator #}
    <div class="ed-stat-block">
      <span class="ed-stat-heading">Afstaða</span>
      <div class="ed-stance">
        <div class="et-stance-track">
          <div class="et-stance-dot" style="left: {{ dotLeft }}%"></div>
        </div>
        <span class="ed-stance-label">{{ stanceLabel }}</span>
      </div>
    </div>

    {# Total claims #}
    <div class="ed-stat-block">
      <span class="ed-stat-heading">Fullyrðingar</span>
      <span class="ed-stat-num">{{ totalClaims }}</span>
    </div>

    {# Articles #}
    <div class="ed-stat-block">
      <span class="ed-stat-heading">Greinar</span>
      <span class="ed-stat-num">{{ entity.articles | length }}</span>
    </div>
  </div>

  {# ── Attribution breakdown ── #}
  {% set ac = entity.attribution_counts %}
  {% if ac %}
    {% set attrOrder = ["quoted", "asserted", "paraphrased", "mentioned"] %}
    {% set attrTotal = 0 %}
    {% for k in attrOrder %}
      {% set attrTotal = attrTotal + (ac[k] or 0) %}
    {% endfor %}
    {% if attrTotal > 0 %}
    <div class="ed-attribution">
      <div class="et-attr-bar">
        {% for k in attrOrder %}
          {% if ac[k] %}
            {% set pct = (ac[k] / attrTotal * 100) | round(1) %}
            <div class="et-attr-seg et-attr-{{ k }}" style="width:{{ pct }}%" title="{{ k | attributionLabel }}: {{ ac[k] }}"></div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="et-attr-legend">
        {% for k in attrOrder %}
          {% if ac[k] %}
            <span class="et-attr-legend-item et-attr-{{ k }}-text">{{ k | attributionLabel }} {{ ac[k] }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
  {% endif %}

  {# ── Outlet coverage (for media entities) ── #}
  {% if entity.subtype == "media" and entity.outlet_articles and entity.outlet_articles | length %}
  {% set oa = entity.outlet_articles %}
  {% set os = entity.outlet_stats %}
  {% set osc = entity.outlet_scorecard %}

  <section class="ed-outlet-coverage">
    <h2>Umfjöllun</h2>

    <div class="ed-outlet-agg">
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Greinar</span>
        <span class="ed-stat-num">{{ os.article_count }}</span>
      </div>
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Fullyrðingar</span>
        <span class="ed-stat-num">{{ os.total_claims }}</span>
      </div>
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Ræðumenn</span>
        <span class="ed-stat-num">{{ os.unique_speakers }}</span>
      </div>
      {% if os.date_range and os.date_range.first %}
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Tímabil</span>
        <span class="ed-stat-period">{{ os.date_range.first | isDate }} – {{ os.date_range.last | isDate }}</span>
      </div>
      {% endif %}
    </div>

    {# Aggregate verdict bar across all outlet articles #}
    {% set oscTotal = 0 %}
    {% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
    {% for v in verdictOrder %}
      {% set oscTotal = oscTotal + (osc[v] or 0) %}
    {% endfor %}

    {% if oscTotal > 0 %}
    <div class="report-verdict-bar" role="img" aria-label="Dreifing niðurstaðna í umfjöllun">
      {% for v in verdictOrder %}
        {% set count = osc[v] %}
        {% if count %}
          {% set pct = (count / oscTotal * 100) | round(1) %}
          <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                style="width:{{ pct }}%"
                title="{{ v | verdictLabel }}: {{ count }}">
            {%- if pct >= 15 %}{{ pct | round }}%{% endif -%}
          </span>
        {% endif %}
      {% endfor %}
    </div>
    <div class="verdict-summary">
      {% for v in verdictOrder %}
        {% if osc[v] %}
        <span class="ct-verdict-pill verdict-{{ v | replace("partially_supported", "partial") }}" title="{{ v | verdictDescription }}">
          {{ v | verdictLabel }}: {{ osc[v] }}
        </span>
        {% endif %}
      {% endfor %}
    </div>
    <p class="ed-scorecard-note">Dreifing niðurstaðna yfir allar fullyrðingar sem birtust í umfjöllun {{ entity.name }}.</p>
    {% endif %}

    {# Topic distribution chips #}
    {% if os.topic_distribution %}
    <div class="ed-outlet-topics">
      <h3>Málefni</h3>
      <div class="ed-topic-chips">
        {% for topic, count in os.topic_distribution | dictsort(false, 'value') | reverse %}
          <span class="ct-category-tag">{{ topic | categoryLabel }} <small>({{ count }})</small></span>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {# Article list #}
    <div class="ed-outlet-articles">
      <h3>Greinar ({{ oa | length }})</h3>
      <div class="ed-articles-grid">
        {% for art in oa %}
        <a href="/umraedan/{{ art.slug }}/" class="ed-article-card">
          <h4 class="ed-article-title">{{ art.title }}</h4>
          <div class="ed-article-meta">
            {% if art.source %}<span class="ed-article-source">{{ art.source }}</span>{% endif %}
            {% if art.date %}<time datetime="{{ art.date }}">{{ art.date | isDate }}</time>{% endif %}
          </div>
          <div class="ed-article-stats">
            <span>{{ art.claim_count }} fullyrðing{{ "ar" if art.claim_count > 1 else "" }}</span>
          </div>
          {# Mini verdict bar per article #}
          {% set artTotal = 0 %}
          {% for v in verdictOrder %}
            {% set artTotal = artTotal + (art.verdict_counts[v] or 0) %}
          {% endfor %}
          {% if artTotal > 0 %}
          <div class="report-verdict-bar ed-mini-verdict" role="img">
            {% for v in verdictOrder %}
              {% set count = art.verdict_counts[v] %}
              {% if count %}
                {% set pct = (count / artTotal * 100) | round(1) %}
                <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                      style="width:{{ pct }}%"
                      title="{{ v | verdictLabel }}: {{ count }}"></span>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {# ── Party members (for party entities) ── #}
  {% if entity.type == "party" and entity.party_members and entity.party_members | length %}
  {% set members = entity.party_members %}
  {% set memberCount = members | length %}

  {# Aggregate stats #}
  {% set totalClaims_pm = 0 %}
  {% set stanceSum = 0 %}
  {% for m in members %}
    {% set totalClaims_pm = totalClaims_pm + (m.claim_count or 0) %}
    {% if m.stance_score is number %}
      {% set stanceSum = stanceSum + m.stance_score %}
    {% endif %}
  {% endfor %}

  <section class="ed-party-members">
    <h2>Þingmenn í umræðunni ({{ memberCount }})</h2>

    <div class="ed-party-agg">
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Fullyrðingar</span>
        <span class="ed-stat-num">{{ totalClaims_pm }}</span>
      </div>
    </div>

    <div class="ed-members-grid">
      {% for m in members %}
      {% set mScore = m.stance_score or 0 %}
      {% if mScore >= 0 %}
        {% set mHue = 60 + mScore * 150 %}
      {% else %}
        {% set mHue = 60 + mScore * 60 %}
      {% endif %}
      {% set mSat = 10 + (mScore if mScore >= 0 else -mScore) * 60 %}
      {% set mDotLeft = ((mScore + 1) / 2 * 100) %}

      <a href="/raddirnar/{{ m.slug }}/" class="ed-member-card" style="--stance-hue: {{ mHue }}; --stance-sat: {{ mSat }}%">
        <div class="ed-member-top">
          <span class="ed-member-name">{{ m.name }}</span>
          <div class="et-stance-track ed-member-stance">
            <div class="et-stance-dot" style="left: {{ mDotLeft }}%"></div>
          </div>
        </div>
        {% if m.role %}
          <span class="ed-member-role">{{ m.role | capitalize }}</span>
        {% endif %}
        <div class="ed-member-stats">
          {% if m.claim_count %}<span>{{ m.claim_count }} fullyrðing{{ "ar" if m.claim_count > 1 else "" }}</span>{% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── Þingvirkni (Alþingi parliamentary activity) ── #}
  {% if entity.althingi_stats %}
  {% set as = entity.althingi_stats %}
  <section class="ed-althingi">
    <h2>Þingvirkni um ESB-mál</h2>
    <div class="ed-althingi-stats">
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Ræður</span>
        <span class="ed-stat-num">{{ as.speech_count }}</span>
      </div>
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Orð samtals</span>
        <span class="ed-stat-num">{{ as.total_words | localeString }}</span>
      </div>
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Þingmál</span>
        <span class="ed-stat-num">{{ as.issues }}</span>
      </div>
      <div class="ed-stat-block">
        <span class="ed-stat-heading">Tímabil</span>
        <span class="ed-stat-period">{{ as.first_speech | isDate }} – {{ as.last_speech | isDate }}</span>
      </div>
    </div>
    <p class="ed-althingi-note">Ræður á Alþingi um ESB- og Evrópumál.</p>
    <a href="/thingraedur/?speaker={{ entity.name | urlencode }}" class="ed-althingi-link">Sjá þingræður &rarr;</a>
  </section>
  {% endif %}

  {# ── Scorecard (verdict bar) ── #}
  {% if scorecardTotal > 0 %}
  <section class="ed-scorecard">
    <h2>Yfirlit</h2>

    {% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
    <div class="report-verdict-bar" role="img" aria-label="Dreifing niðurstaðna">
      {% for v in verdictOrder %}
        {% set count = entity.scorecard[v] %}
        {% if count %}
          {% set pct = (count / scorecardTotal * 100) | round(1) %}
          <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                style="width:{{ pct }}%"
                title="{{ v | verdictLabel }}: {{ count }}">
            {%- if pct >= 15 %}{{ pct | round }}%{% endif -%}
          </span>
        {% endif %}
      {% endfor %}
    </div>

    <div class="verdict-summary">
      {% for v in verdictOrder %}
        {% if entity.scorecard[v] %}
        <span class="ct-verdict-pill verdict-{{ v | replace("partially_supported", "partial") }}" title="{{ v | verdictDescription }}">
          {{ v | verdictLabel }}: {{ entity.scorecard[v] }}
        </span>
        {% endif %}
      {% endfor %}
    </div>

    <p class="ed-scorecard-note">Aðeins fullyrðingar sem aðilinn hefur fullyrt, verið vitnað í, eða umorðað eru taldar.</p>
  </section>
  {% endif %}

  {# ── Claims ── #}
  {% if totalClaims > 0 %}
  <section class="ed-claims">
    <h2>Fullyrðingar ({{ totalClaims }})</h2>

    {% for item in entity.claims %}
    <details class="report-claim report-claim--{{ item.verdict | replace("partially_supported", "partial") }}">
      <summary class="report-claim-header">
        <span class="ct-verdict-pill verdict-{{ item.verdict | replace("partially_supported", "partial") }}" title="{{ item.verdict | verdictDescription }}">
          {{ item.verdict | verdictLabel }}
        </span>
        <span class="report-claim-title">{{ item.claim_text }}</span>
        <span class="ed-attr-badge ed-attr-{{ item.attribution }}">{{ item.attribution | attributionLabel }}</span>
        {% if item.category %}
          <span class="ct-category-tag">{{ item.category | categoryLabel }}</span>
        {% endif %}
        <span class="report-claim-chevron" aria-hidden="true"></span>
      </summary>
      <div class="report-claim-body">
        {% if item.original_quote %}
          <blockquote class="report-quote">{{ item.original_quote }}</blockquote>
        {% endif %}
        {% if item.explanation %}
          <p class="report-explanation">{{ item.explanation | evidenceLinks | safe }}</p>
        {% endif %}
        {% if item.missing_context %}
          <details class="report-context">
            <summary>Samhengi sem vantar</summary>
            <p>{{ item.missing_context | evidenceLinks | safe }}</p>
          </details>
        {% endif %}
        {% if item.supporting_evidence | length %}
        <div class="report-evidence">
          <strong>Heimildir:</strong>
          {% for ev in item.supporting_evidence %}
            <a href="/heimildir/{{ ev.id | lower }}/" class="evidence-link" data-evidence-id="{{ ev.id }}" data-preserve-return>{{ ev.id }}</a>
            {%- if not loop.last %}, {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        {% if item.contradicting_evidence | length %}
        <div class="report-evidence report-evidence-contra">
          <strong>Andstæðar heimildir:</strong>
          {% for ev in item.contradicting_evidence %}
            <a href="/heimildir/{{ ev.id | lower }}/" class="evidence-link" data-evidence-id="{{ ev.id }}" data-preserve-return>{{ ev.id }}</a>
            {%- if not loop.last %}, {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        <p class="ed-claim-source">
          <a href="/umraedan/{{ item.article_slug }}/" data-preserve-return>{{ item.article_title }}</a>
          {% if item.article_source %}<span class="ed-claim-source-name">{{ item.article_source }}</span>{% endif %}
          {% if item.article_date %}<time datetime="{{ item.article_date }}">{{ item.article_date | isDate }}</time>{% endif %}
        </p>
      </div>
    </details>
    {% endfor %}
  </section>
  {% endif %}

  {# ── Articles ── #}
  {% if entity.articles | length %}
  <section class="ed-articles">
    <h2>Greinar ({{ entity.articles | length }})</h2>

    <div class="ed-articles-grid">
      {% for art in entity.articles %}
      <a href="/umraedan/{{ art.slug }}/" class="ed-article-card">
        <h3 class="ed-article-title">{{ art.title }}</h3>
        <div class="ed-article-meta">
          {% if art.source %}<span class="ed-article-source">{{ art.source }}</span>{% endif %}
          {% if art.date %}<time datetime="{{ art.date }}">{{ art.date | isDate }}</time>{% endif %}
        </div>
        <div class="ed-article-stats">
          <span>{{ art.claim_count }} fullyrðing{{ "ar" if art.claim_count > 1 else "" }}</span>
          {% for at in art.attribution_types %}
            <span class="ed-attr-badge ed-attr-{{ at }}">{{ at | attributionLabel }}</span>
          {% endfor %}
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</article>
