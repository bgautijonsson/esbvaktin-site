---
layout: base.njk
extra_css: /assets/css/overview-detail.css
return_link_support: true
evidence_preview: true
---

{% set kn = overview.key_numbers %}
{% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
{% set attrOrder = ["quoted", "asserted", "paraphrased", "mentioned"] %}
{% set verdictTotal = 0 %}
{% if kn.verdict_breakdown %}
  {% for v in verdictOrder %}
    {% set verdictTotal = verdictTotal + (kn.verdict_breakdown[v] or 0) %}
  {% endfor %}
{% endif %}

<article class="od-overview">
  {# ── Back link ── #}
  <a href="/vikuyfirlit/" class="od-back" data-return-link data-return-fallback="/vikuyfirlit/" data-return-label="← Til baka í fyrri niðurstöður">&larr; Til baka á Vikuyfirlit</a>

  {# ── Header ── #}
  <header class="od-header">
    <h1 class="od-title">Vikuyfirlit {{ overview.period_start | isDateRange(overview.period_end) }}</h1>
  </header>

  {# ── Editorial (lead section — collapsed after 2 paragraphs) ── #}
  {% if overview.editorial %}
  <section class="od-editorial">
    <p class="od-ai-disclosure">Vikuyfirlitið er skrifað af gervigreindarlíkaninu Claude með hjálp tengingar við gagnagrunn ESB Vaktarinnar.</p>
    {% set editorialHtml = overview.editorial | markdown | safe %}
    {{ editorialHtml }}
  </section>
  {% endif %}

  {# ── Snapshot strip (stats + verdict bar + top topics) ── #}
  {% if kn %}
  <section class="od-snapshot">
    <div class="od-snapshot-stats">
      <div class="od-stat-block">
        <span class="od-stat-heading">Greinar</span>
        <span class="od-stat-num">{{ kn.articles_analysed }}</span>
      </div>
      <div class="od-stat-block">
        <span class="od-stat-heading">Fullyrðingar</span>
        <span class="od-stat-num">{{ kn.new_claims_published }}</span>
      </div>
      <div class="od-stat-block">
        <span class="od-stat-heading">Málefni</span>
        <span class="od-stat-num">{{ kn.topics_active }}</span>
      </div>
      <div class="od-stat-block">
        <span class="od-stat-heading">Aðilar</span>
        <span class="od-stat-num">{{ kn.entities_active }}</span>
      </div>
      {% if kn.diversity_score %}
      <div class="od-stat-block">
        <span class="od-stat-heading">Fjölbreytni</span>
        <span class="od-stat-num">{{ (kn.diversity_score * 100) | round }}%</span>
      </div>
      {% endif %}
    </div>

    {% if verdictTotal > 0 %}
    <div class="od-snapshot-verdicts">
      <div class="report-verdict-bar" role="img" aria-label="Dreifing niðurstaðna">
        {% for v in verdictOrder %}
          {% set count = kn.verdict_breakdown[v] or 0 %}
          {% if count %}
            {% set pct = (count / verdictTotal * 100) | round(1) %}
            <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                  style="width:{{ pct }}%"
                  title="{{ v | verdictLabel }}: {{ count }}">
              {%- if pct >= 15 %}{{ pct | round }}%{% endif -%}
            </span>
          {% endif %}
        {% endfor %}
      </div>
      <div class="verdict-summary">
        {% for v in verdictOrder %}
          {% set count = kn.verdict_breakdown[v] or 0 %}
          {% if count %}
          <span class="ct-verdict-pill verdict-{{ v | replace("partially_supported", "partial") }}" title="{{ v | verdictDescription }}">
            {{ v | verdictLabel }}: {{ count }}
          </span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {# Top 3 topics inline #}
    {% if overview.topic_activity | length %}
    <div class="od-snapshot-topics">
      {% set maxSightings = overview.topic_activity[0].sightings %}
      {% for ta in overview.topic_activity | slice(0, 3) %}
      <a href="/malefni/{{ ta.slug }}/" class="od-snapshot-topic">
        <span class="od-snapshot-topic-label">{{ ta.label_is }}</span>
        <div class="od-snapshot-topic-track">
          <div class="od-snapshot-topic-fill" style="width: {{ (ta.sightings / maxSightings * 100) | round(1) }}%"></div>
        </div>
        <span class="od-snapshot-topic-count">{{ ta.sightings }}</span>
      </a>
      {% endfor %}
    </div>
    {% endif %}
  </section>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════
     Key facts — well-supported, verifiable claims with caveats
     ══════════════════════════════════════════════════════════════════ #}
  {% if overview.key_facts | length %}
  <section class="od-key-facts od-section">
    <p class="od-section-label">Staðreyndir</p>
    <h2>Vissir þú?</h2>
    <p class="od-key-facts-intro">Staðreyndir úr umræðunni sem eru studdar heimildum — og fyrirvarar sem gott er að hafa í huga.</p>
    {% for fact in overview.key_facts %}
      {% set confidencePct = (fact.confidence * 100) | round if fact.confidence is number else 0 %}
    <div class="od-fact-card" data-slug="{{ fact.claim_slug }}">
      {# ── Clickable header (expand/collapse) ── #}
      <div class="od-fact-header" role="button" tabindex="0" aria-expanded="false">
        <div class="od-fact-header-top">
          <span class="ct-verdict-pill verdict-{{ fact.verdict | replace('partially_supported', 'partial') }}" title="{{ fact.verdict | verdictDescription }}">
            {{ fact.verdict | verdictLabel }}
          </span>
          <span class="ct-category-tag">{{ fact.category_is }}</span>
          {% if fact.claim_type == "statistic" %}
            <span class="od-fact-type-badge">Tölulegt</span>
          {% elif fact.claim_type == "comparison" %}
            <span class="od-fact-type-badge">Samanburður</span>
          {% endif %}
        </div>
        <p class="od-fact-text">{{ fact.claim_text }}</p>
        <div class="od-fact-header-meta">
          <span class="ct-confidence" title="Vissustig">
            <span class="ct-confidence-bar" style="width: {{ confidencePct }}%"></span>
            {{ confidencePct }}%
          </span>
          <span class="ct-expand-icon">▸</span>
        </div>
      </div>

      {# ── Expandable details ── #}
      <div class="od-fact-details">
        {% if fact.explanation %}
          <div class="od-fact-detail">
            <strong>Af hverju?</strong> {{ fact.explanation | evidenceLinksFromText | safe }}
          </div>
        {% endif %}
        {% if fact.caveat %}
          <div class="od-fact-detail od-fact-caveat">
            <strong>Gott að vita:</strong> {{ fact.caveat | evidenceLinksFromText | safe }}
          </div>
        {% endif %}
        {# Deep link to Fullyrðingar #}
        {% if fact.claim_slug %}
          <div class="od-fact-detail od-fact-deeplink">
            <a href="/fullyrdingar/?claim={{ fact.claim_slug }}">Sjá fulla greiningu →</a>
          </div>
        {% endif %}
        {# Topic link #}
        {% if fact.category %}
          <div class="od-fact-detail od-fact-deeplink">
            <a href="/malefni/{{ fact.category }}/">Sjá málefni: {{ fact.category_is }} →</a>
          </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════
     Top claims — expandable cards matching Fullyrðingar tracker
     ══════════════════════════════════════════════════════════════════ #}
  {% if overview.top_claims | length %}
  <section class="od-top-claims od-section">
    <p class="od-section-label">Fullyrðingar</p>
    <h2>Helstu fullyrðingar</h2>

    {# Context-needed claims prompt #}
    {% set contextTop = [] %}
    {% for item in overview.top_claims %}
      {% if loop.index0 < 5 and item.verdict == "misleading" %}
        {% set contextTop = contextTop.concat([item]) %}
      {% endif %}
    {% endfor %}
    {% if contextTop | length >= 2 %}
    <div class="od-claims-alert od-claims-alert--context">
      Nokkrar fullyrðingar vikunnar þarfnast nánara samhengis — smelltu til að sjá hvað heimildir segja.
    </div>
    {% endif %}

    <div class="od-claims-list">
    {% for item in overview.top_claims %}
      {% set confidencePct = (item.confidence * 100) | round if item.confidence is number else 0 %}
      <div class="od-claim-card ct-card" data-slug="{{ item.claim_slug }}">
        {# ── Clickable header (expand/collapse) ── #}
        <div class="ct-card-header" role="button" tabindex="0" aria-expanded="false">
          <div class="ct-card-main">
            <span class="ct-verdict-pill verdict-{{ item.verdict | replace('partially_supported', 'partial') }}" title="{{ item.verdict | verdictDescription }}">
              {{ item.verdict | verdictLabel }}
            </span>
            <span class="ct-category-tag">{{ item.category_is }}</span>
            {% if item.sighting_count and item.sighting_count > 1 %}
              <span class="ct-sighting-count" title="Fjöldi tilvitana">{{ item.sighting_count }}×</span>
            {% endif %}
          </div>
          <p class="ct-claim-text">{{ item.canonical_text_is }}</p>
          <div class="ct-card-meta">
            <span class="ct-confidence" title="Vissustig">
              <span class="ct-confidence-bar" style="width: {{ confidencePct }}%"></span>
              {{ confidencePct }}%
            </span>
            <span class="ct-expand-icon">▸</span>
          </div>
        </div>

        {# ── Expandable details ── #}
        <div class="ct-card-details">
          {% if item.explanation_is %}
            <div class="ct-detail"><strong>Útskýring:</strong> {{ item.explanation_is | evidenceLinksFromText | safe }}</div>
          {% endif %}
          {% if item.missing_context_is %}
            <div class="ct-detail"><strong>Samhengi sem vantar:</strong> {{ item.missing_context_is | evidenceLinksFromText | safe }}</div>
          {% endif %}
          {% if item.canonical_text_en %}
            <div class="ct-detail ct-english"><strong>English:</strong> {{ item.canonical_text_en }}</div>
          {% endif %}

          {# Sightings (source articles) #}
          {% if item.sightings | length %}
            <div class="ct-detail ct-sightings">
              <strong>Umræðan:</strong>
              <ul class="ct-sighting-list">
                {% for s in item.sightings %}
                  <li class="ct-sighting-item">
                    {% set matchedSlug = "" %}
                    {% for src in item.sources %}
                      {% if src.title == s.source_title %}{% set matchedSlug = src.slug %}{% endif %}
                    {% endfor %}
                    {% if matchedSlug %}
                      <a href="/umraedan/{{ matchedSlug }}/">{{ s.source_title }}</a>
                    {% elif s.source_url %}
                      <a href="{{ s.source_url }}" target="_blank" rel="noopener">{{ s.source_title }}</a>
                    {% else %}
                      <span>{{ s.source_title }}</span>
                    {% endif %}
                    {% set typeLabels = { "news": "Frétt", "opinion": "Skoðun", "althingi": "Alþingi", "interview": "Viðtal", "analysis": "Greining", "panel_show": "Þáttur", "other": "Annað" } %}
                    {% set meta = [] %}
                    {% if s.source_type and typeLabels[s.source_type] %}{% set meta = meta.concat([typeLabels[s.source_type]]) %}{% endif %}
                    {% if s.source_date %}{% set meta = meta.concat([s.source_date | isDate]) %}{% endif %}
                    {% if meta | length %}
                      <span class="ct-sighting-meta">{{ meta | join(" · ") }}</span>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          {# Deep link to Fullyrðingar page #}
          {% if item.claim_slug %}
            <div class="ct-detail od-claim-deeplink">
              <a href="/fullyrdingar/?claim={{ item.claim_slug }}">Sjá fulla greiningu á Fullyrðingum →</a>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════
     Topic activity — horizontal bar chart
     ══════════════════════════════════════════════════════════════════ #}
  {% if overview.topic_activity | length %}
  <section class="od-topics od-section">
    <p class="od-section-label">Málefni</p>
    <h2>Virkni eftir málefnum</h2>
    {% set maxSightings = overview.topic_activity[0].sightings %}
    <div class="od-topic-bars">
      {% for ta in overview.topic_activity %}
        {% set pct = (ta.sightings / maxSightings * 100) | round(1) %}
      <a href="/malefni/{{ ta.slug }}/" class="od-topic-row">
        <span class="od-topic-label">{{ ta.label_is }}</span>
        <div class="od-topic-bar-track">
          <div class="od-topic-bar-fill" style="width: {{ pct }}%"></div>
        </div>
        <span class="od-topic-count">{{ ta.sightings }}</span>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════
     Active entities — compact cards
     ══════════════════════════════════════════════════════════════════ #}
  {% if overview.active_entities | length %}
  <section class="od-entities od-section">
    <p class="od-section-label">Aðilar í umræðunni</p>
    <h2>Virkir aðilar</h2>
    <div class="od-entity-grid">
      {% for ent in overview.active_entities %}
        {# Compute stance hue/sat for CSS custom properties #}
        {% set es = ent.stance_score or 0 %}
        {% if es >= 0 %}{% set eHue = 60 + es * 150 %}{% else %}{% set eHue = 60 + es * 60 %}{% endif %}
        {% set eSat = 10 + (es if es >= 0 else -es) * 60 %}
        {% if es >= 0.5 %}{% set eStanceLabel = "ESB-jákvæð" %}
        {% elif es <= -0.5 %}{% set eStanceLabel = "ESB-gagnrýnin" %}
        {% elif es > -0.1 and es < 0.1 %}{% set eStanceLabel = "Hlutlaus" %}
        {% else %}{% set eStanceLabel = "Blandað" %}{% endif %}
      <a href="/raddirnar/{{ ent.slug }}/" class="od-entity-card" style="--stance-hue: {{ eHue }}; --stance-sat: {{ eSat }}%">
        <div class="od-entity-top">
          <h3 class="od-entity-name">{{ ent.name }}</h3>
          {% if ent.stance_score is number %}
          <span class="od-stance-label">{{ eStanceLabel }}</span>
          {% endif %}
        </div>

        {% if ent.role %}
          <p class="od-entity-role">{{ ent.role }}{% if ent.party %} ({{ ent.party }}){% endif %}</p>
        {% endif %}

        <div class="od-entity-stats">
          <span class="od-entity-stat">{{ ent.claims_made }} fullyrðing{{ "ar" if ent.claims_made > 1 else "" }}</span>
          {% if ent.top_topics | length %}
            <span class="od-entity-stat od-entity-topics">{{ ent.top_topics | join(", ") }}</span>
          {% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════
     Articles analysed — rich cards matching Umræðan tracker
     ══════════════════════════════════════════════════════════════════ #}
  {% if overview.articles | length %}
  <section class="od-articles od-section">
    <p class="od-section-label">Greiningar</p>
    <h2>Greiningar ({{ overview.articles | length }})</h2>
    <div class="od-articles-grid">
      {% for art in overview.articles %}
        {# Verdict bar total #}
        {% set artTotal = 0 %}
        {% if art.verdict_counts %}
          {% for v in verdictOrder %}
            {% set artTotal = artTotal + (art.verdict_counts[v] or 0) %}
          {% endfor %}
        {% endif %}
      <a href="/umraedan/{{ art.slug or (art.title | isSlug) }}/" class="od-article-card">
        {# Source badge + date #}
        <div class="od-article-top">
          {% if art.source %}
            <span class="dt-source-badge {{ art.source | sourceClass }}">{{ art.source | sourceName }}</span>
          {% endif %}
          {% if art.date %}<time datetime="{{ art.date }}">{{ art.date | isDate }}</time>{% endif %}
        </div>

        <h3 class="od-article-title">{{ art.title }}</h3>

        {% if art.article_author %}
          <span class="od-article-author">{{ art.article_author }}</span>
        {% endif %}

        {# Summary (3-line clamp) #}
        {% if art.summary and art.summary | length > 30 %}
          <p class="od-article-summary">{{ art.summary }}</p>
        {% endif %}

        {# Verdict bar (full height like discourse tracker) #}
        {% if artTotal > 0 %}
        <div class="od-article-verdict-bar" role="img" aria-label="Niðurstöður">
          {% for v in verdictOrder %}
            {% set count = art.verdict_counts[v] or 0 %}
            {% if count %}
              {% set pct = (count / artTotal * 100) | round(1) %}
              <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                    style="width:{{ pct }}%"
                    title="{{ v | verdictLabel }}: {{ count }}">
                {%- if pct >= 15 %}{{ pct | round }}%{% endif -%}
              </span>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}

        {# Stats row #}
        <div class="od-article-stats">
          <span class="od-article-claims">{{ art.claim_count }} fullyrðing{{ "ar" if art.claim_count > 1 else "" }}</span>
          {% if art.participants | length %}
            <span class="od-article-participants">{{ art.participants | length }} þátttakend{{ "ur" if art.participants | length > 1 else "i" }}</span>
          {% endif %}
        </div>

        {# Participant name chips #}
        {% if art.participants | length %}
        <div class="od-article-speakers">
          {% for p in art.participants %}
            <span class="od-article-speaker" title="{{ p.name or 'Óþekkt' }}{% if p.party %} ({{ p.party }}){% endif %}">{{ (p.name or "?").split(" ")[0] }}</span>
          {% endfor %}
        </div>
        {% endif %}

        {# Category tags #}
        {% if art.categories | length %}
        <div class="od-article-categories">
          {% for cat in art.categories | slice(0, 4) %}
            <span class="ct-category-tag od-article-cat-tag">{{ cat | categoryLabel }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</article>

{# ── Inline JS for expandable cards + editorial collapse ── #}
<script>
(function() {
  function bindExpandable(containerSel, cardSel, headerSel, expandedClass) {
    var cards = document.querySelectorAll(containerSel + ' ' + cardSel);
    cards.forEach(function(card) {
      var header = card.querySelector(headerSel);
      if (!header) return;
      function toggle() {
        var expanded = !card.classList.contains(expandedClass);
        card.classList.toggle(expandedClass, expanded);
        header.setAttribute('aria-expanded', expanded);
      }
      header.addEventListener('click', toggle);
      header.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
      });
    });
  }
  bindExpandable('.od-top-claims', '.ct-card', '.ct-card-header', 'ct-expanded');
  bindExpandable('.od-key-facts', '.od-fact-card', '.od-fact-header', 'od-fact-expanded');

  /* Editorial collapse — show first 2 <p> then hide the rest */
  var editorial = document.querySelector('.od-editorial');
  if (editorial) {
    var children = Array.from(editorial.children);
    var pCount = 0;
    var hideFrom = -1;
    for (var i = 0; i < children.length; i++) {
      if (children[i].tagName === 'P' && !children[i].classList.contains('od-ai-disclosure')) {
        pCount++;
        if (pCount === 3 && hideFrom === -1) { hideFrom = i; }
      }
    }
    if (hideFrom > 0) {
      var moreDiv = document.createElement('div');
      moreDiv.className = 'od-editorial-more';
      for (var j = children.length - 1; j >= hideFrom; j--) {
        moreDiv.insertBefore(children[j], moreDiv.firstChild);
      }
      editorial.appendChild(moreDiv);

      var btn = document.createElement('button');
      btn.className = 'od-editorial-toggle';
      btn.textContent = 'Lesa allt yfirlitið ▸';
      btn.setAttribute('aria-expanded', 'false');
      editorial.insertBefore(btn, moreDiv);

      btn.addEventListener('click', function() {
        var expanded = editorial.classList.toggle('od-editorial-expanded');
        btn.setAttribute('aria-expanded', expanded);
        btn.textContent = expanded ? 'Minna ▾' : 'Lesa allt yfirlitið ▸';
      });
    }
  }
})();
</script>
