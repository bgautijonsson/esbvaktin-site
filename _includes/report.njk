---
layout: base.njk
og_type: article
---

<article class="report">
  <header class="report-header">
    <h1>{{ report.article_title }}</h1>
    <div class="report-meta">
      {% if report.article_source %}
        {% if report.article_url %}
          <a href="{{ report.article_url }}" class="report-source-link" target="_blank" rel="noopener">{{ report.article_source }} &#x2197;</a>
        {% else %}
          <span class="report-source">{{ report.article_source }}</span>
        {% endif %}
      {% endif %}
      {% if report.article_author %}<span class="report-author">{{ report.article_author }}</span>{% endif %}
      {% if report.article_date %}<time datetime="{{ report.article_date }}">{{ report.article_date | isDate }}</time>{% endif %}
    </div>
    <p class="report-summary">{{ report.summary }}</p>
  </header>

  {% if report.verdict_counts %}
  <section class="report-verdicts">
    <h2>Niðurstöður</h2>
    <div class="verdict-summary">
      {% for verdict, count in report.verdict_counts %}
      <span class="ct-verdict-pill verdict-{{ verdict | replace("partially_supported", "partial") }}">
        {{ verdict | verdictLabel }}: {{ count }}
      </span>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <section class="report-claims">
    <h2>Fullyrðingar ({{ report.claims | length }})</h2>
    {% for item in report.claims %}
    <div class="report-claim">
      <div class="report-claim-header">
        <span class="ct-verdict-pill verdict-{{ item.verdict | replace("partially_supported", "partial") }}">
          {{ item.verdict | verdictLabel }}
        </span>
        <span class="ct-category-tag">{{ item.claim.category | categoryLabel }}</span>
      </div>
      <blockquote class="report-quote">{{ item.claim.original_quote }}</blockquote>
      {% if item.claim.claim_text %}
      <p class="report-claim-text"><strong>Fullyrðing:</strong> {{ item.claim.claim_text }}</p>
      {% endif %}
      <p class="report-explanation">{{ item.explanation | safe }}</p>
      {% if item.missing_context %}
      <details class="report-context">
        <summary>Samhengi sem vantar</summary>
        <p>{{ item.missing_context | safe }}</p>
      </details>
      {% endif %}
      {% if item.supporting_evidence | length %}
      <div class="report-evidence">
        <strong>Heimildir:</strong>
        {% for ev in item.supporting_evidence %}
          {% if ev.source_url %}
            <a href="{{ ev.source_url }}" target="_blank" rel="noopener" class="evidence-link" title="{{ ev.source_name }}">{{ ev.id }}</a>
          {% else %}
            <span class="evidence-ref" title="{{ ev.source_name }}">{{ ev.id }}</span>
          {% endif %}
          {%- if not loop.last %}, {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      {% if item.contradicting_evidence | length %}
      <div class="report-evidence report-evidence-contra">
        <strong>Andstæðar heimildir:</strong>
        {% for ev in item.contradicting_evidence %}
          {% if ev.source_url %}
            <a href="{{ ev.source_url }}" target="_blank" rel="noopener" class="evidence-link" title="{{ ev.source_name }}">{{ ev.id }}</a>
          {% else %}
            <span class="evidence-ref" title="{{ ev.source_name }}">{{ ev.id }}</span>
          {% endif %}
          {%- if not loop.last %}, {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </section>
</article>
