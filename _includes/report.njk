---
layout: base.njk
og_type: article
return_link_support: true
evidence_preview: true
---

{# ── Compute total claims for verdict bar widths ── #}
{% set totalClaims = report.claims | length %}

<article class="report">
  <nav class="report-nav" aria-label="Til baka">
    <a href="/umraedan/" class="report-back" data-return-link data-return-fallback="/umraedan/" data-return-label="← Til baka í fyrri niðurstöður">&larr; Til baka í greinayfirlit</a>
  </nav>

  <header class="report-header">
    <h1>{{ report.article_title }}</h1>
    <div class="report-meta">
      {% if report.article_source %}
        {% if report.article_url %}
          <a href="{{ report.article_url }}" class="report-source-link" target="_blank" rel="noopener">{{ report.article_source }} &#x2197;</a>
        {% else %}
          <span class="report-source">{{ report.article_source }}</span>
        {% endif %}
      {% endif %}
      {% if report.article_author %}<span class="report-author">{{ report.article_author }}</span>{% endif %}
      {% if report.article_date %}<time datetime="{{ report.article_date }}">{{ report.article_date | isDate }}</time>{% endif %}
    </div>

    {% if report.participants and report.participants | length %}
    <div class="report-participants">
      <h3>{% if report.source_type == "panel_show" %}Þátttakendur{% else %}Raddir í greininni{% endif %}</h3>
      <div class="report-participants-grid{% if report.participants | length == 1 %} report-participants-single{% endif %}">
        {% for p in report.participants %}
        <div class="report-participant">
          <div class="report-participant-info">
            {% if p.slug %}
            <a href="/raddirnar/{{ p.slug }}/" class="report-participant-name report-participant-link" data-preserve-return>{{ p.name }}</a>
            {% else %}
            <span class="report-participant-name">{{ p.name }}</span>
            {% endif %}
            <span class="report-participant-tags">
              {% if p.role_in_article == "author" %}<span class="report-participant-tag tag-author">Höfundur</span>{% endif %}
              {% if p.attribution_type %}<span class="report-participant-tag tag-attribution">{{ p.attribution_type | attributionLabel }}</span>{% endif %}
              {% if p.stance == "pro_eu" %}<span class="report-participant-tag tag-stance tag-stance-pro" title="Fylgjandi ESB-aðild">●</span>
              {% elif p.stance == "anti_eu" %}<span class="report-participant-tag tag-stance tag-stance-anti" title="Andvíg(ur) ESB-aðild">●</span>{% endif %}
            </span>
            {% if p.party or p.role %}
            <span class="report-participant-role">
              {%- if p.party %}{{ p.party }}{% endif %}{% if p.party and p.role %} — {% endif %}{% if p.role %}{{ p.role }}{% endif -%}
            </span>
            {% endif %}
          </div>
          {% if p.mention_count or p.speech_count %}
          <div class="report-participant-stats">
            {% if p.mention_count > 1 %}<span title="Fjöldi greina">{{ p.mention_count }} greinar</span>{% endif %}
            {% if p.speech_count %}<span title="Þingræður um ESB">{{ p.speech_count | localeString }} þingræður</span>{% endif %}
            {% if p.credibility %}<span title="Trúverðugleiki">{{ (p.credibility * 100) | round(0) }}% trúverðugleiki</span>{% endif %}
          </div>
          {% endif %}
          <div class="report-participant-verdicts">
            <span class="report-participant-count">{{ p.claim_count }} fullyrðingar</span>
            {% set verdictOrder = ["supported", "partially_supported", "unverifiable", "misleading", "unsupported"] %}
            <div class="report-verdict-bar" role="img" aria-label="Dreifing niðurstaðna">
              {% for v in verdictOrder %}
                {% if p.verdicts[v] %}
                  {% set pct = (p.verdicts[v] / p.claim_count * 100) | round(1) %}
                  <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                        style="width:{{ pct }}%"
                        title="{{ v | verdictLabel }}: {{ p.verdicts[v] }}">
                    {%- if pct >= 12 %}{{ p.verdicts[v] }}{% endif -%}
                  </span>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <p class="report-summary">{{ report.summary }}</p>
  </header>

  {# ── Phase 2: Verdict summary bar ── #}
  {% if report.verdict_counts %}
  <section class="report-verdicts">
    <h2>Niðurstöður</h2>

    {# Stacked verdict bar #}
    {% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
    <div class="report-verdict-bar" role="img" aria-label="Dreifing niðurstaðna">
      {% for v in verdictOrder %}
        {% set count = report.verdict_counts[v] %}
        {% if count %}
          {% set pct = (count / totalClaims * 100) | round(1) %}
          <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                style="width:{{ pct }}%"
                title="{{ v | verdictLabel }}: {{ count }}">
            {%- if pct >= 12 %}{{ count }}{% endif -%}
          </span>
        {% endif %}
      {% endfor %}
    </div>

    {# Legend + pills #}
    <div class="verdict-summary">
      {% for verdict, count in report.verdict_counts %}
      <span class="ct-verdict-pill verdict-{{ verdict | replace("partially_supported", "partial") }}">
        {{ verdict | verdictLabel }}: {{ count }}
      </span>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── Claims list with expand/collapse ── #}
  <section class="report-claims">
    <div class="report-claims-toolbar">
      <h2>Fullyrðingar ({{ totalClaims }})</h2>
      <button class="report-toggle-all" type="button" data-action="expand">Opna allar</button>
    </div>

    {% for item in report.claims %}
    {# Phase 3: Verdict-coloured left border via modifier class #}
    <details class="report-claim report-claim--{{ item.verdict | replace("partially_supported", "partial") }}">
      <summary class="report-claim-header">
        <span class="ct-verdict-pill verdict-{{ item.verdict | replace("partially_supported", "partial") }}">
          {{ item.verdict | verdictLabel }}
        </span>
        <span class="report-claim-title">{{ item.claim.claim_text or item.claim.original_quote }}</span>
        <span class="ct-category-tag">{{ item.claim.category | categoryLabel }}</span>
        <span class="report-claim-chevron" aria-hidden="true"></span>
      </summary>

      <div class="report-claim-body">
        <blockquote class="report-quote">{{ item.claim.original_quote }}</blockquote>
        {% if item.claim.claim_text %}
        <p class="report-claim-text"><strong>Fullyrðing:</strong> {{ item.claim.claim_text }}</p>
        {% endif %}
        <p class="report-explanation">{{ item.explanation | evidenceLinks | safe }}</p>
        {% if item.missing_context %}
        <details class="report-context">
          <summary>Samhengi sem vantar</summary>
          <p>{{ item.missing_context | evidenceLinks | safe }}</p>
        </details>
        {% endif %}
        {% if item.supporting_evidence | length %}
        <div class="report-evidence">
          <strong>Heimildir:</strong>
          {% for ev in item.supporting_evidence %}
            <a href="/heimildir/{{ ev.id | lower }}/" class="evidence-link" data-evidence-id="{{ ev.id }}" data-evidence-source="{{ ev.source_name }}" data-preserve-return>{{ ev.id }}</a>
            {%- if not loop.last %}, {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        {% if item.contradicting_evidence | length %}
        <div class="report-evidence report-evidence-contra">
          <strong>Andstæðar heimildir:</strong>
          {% for ev in item.contradicting_evidence %}
            <a href="/heimildir/{{ ev.id | lower }}/" class="evidence-link" data-evidence-id="{{ ev.id }}" data-evidence-source="{{ ev.source_name }}" data-preserve-return>{{ ev.id }}</a>
            {%- if not loop.last %}, {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </details>
    {% endfor %}
  </section>
</article>

<script>
(function () {
  const btn = document.querySelector('.report-toggle-all');
  if (!btn) return;
  const claims = document.querySelectorAll('details.report-claim');

  btn.addEventListener('click', function () {
    const expanding = btn.dataset.action === 'expand';
    claims.forEach(function (d) { d.open = expanding; });
    btn.dataset.action = expanding ? 'collapse' : 'expand';
    btn.textContent = expanding ? 'Loka öllum' : 'Opna allar';
  });
})();
</script>
