---
layout: base.njk
extra_css:
  - /assets/css/topic-detail.css
  - /assets/css/claim-tracker.css
extra_js: /assets/js/topic-claim-tracker.js
return_link_support: true
---

{# ── Verdict totals ── #}
{% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
{% set verdictTotal = 0 %}
{% for c in topic.claims %}
  {% set verdictTotal = verdictTotal + 1 %}
{% endfor %}


<article class="td-topic">
  {# ── Back link ── #}
  <a href="/malefni/" class="td-back" data-return-link data-return-fallback="/malefni/" data-return-label="← Til baka í fyrri niðurstöður">&larr; Til baka á Málefni</a>

  {# ── Header ── #}
  <header class="td-header">
    <h1 class="td-title">{{ topic.label_is }}</h1>
    {% if topic.description_is %}
      <p class="td-description">{{ topic.description_is }}</p>
    {% endif %}
  </header>

  {# ── Stats row ── #}
  <div class="td-stats">
    <div class="td-stat-block">
      <span class="td-stat-heading">Fullyrðingar</span>
      <span class="td-stat-num">{{ topic.claims | length }}</span>
    </div>
    <div class="td-stat-block">
      <span class="td-stat-heading">Heimildir</span>
      <span class="td-stat-num">{{ topic.evidence | length }}</span>
    </div>
    {% if topic.diversity_score %}
    <div class="td-stat-block">
      <span class="td-stat-heading">Fjölbreytni</span>
      <span class="td-stat-num">{{ (topic.diversity_score * 100) | round }}%</span>
    </div>
    {% endif %}
  </div>

  {# ── Verdict breakdown bar ── #}
  {% if verdictTotal > 0 %}
  <section class="td-verdicts">
    <h2>Niðurstöður</h2>
    <div class="report-verdict-bar" role="img" aria-label="Dreifing niðurstaðna">
      {% for v in verdictOrder %}
        {% set count = 0 %}
        {% for c in topic.claims %}
          {% if c.verdict == v %}{% set count = count + 1 %}{% endif %}
        {% endfor %}
        {% if count %}
          {% set pct = (count / verdictTotal * 100) | round(1) %}
          <span class="report-bar-seg verdict-{{ v | replace("partially_supported", "partial") }}"
                style="width:{{ pct }}%"
                title="{{ v | verdictLabel }}: {{ count }}">
            {%- if pct >= 15 %}{{ pct | round }}%{% endif -%}
          </span>
        {% endif %}
      {% endfor %}
    </div>

    <div class="verdict-summary">
      {% for v in verdictOrder %}
        {% set count = 0 %}
        {% for c in topic.claims %}
          {% if c.verdict == v %}{% set count = count + 1 %}{% endif %}
        {% endfor %}
        {% if count %}
        <span class="ct-verdict-pill verdict-{{ v | replace("partially_supported", "partial") }}" title="{{ v | verdictDescription }}">
          {{ v | verdictLabel }}: {{ count }}
        </span>
        {% endif %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── Timeline ── #}
  {% set timelineItems = [] %}
  {% for w in topic.timeline %}
    {% if w.week >= "2026-01-01" %}
      {% set timelineItems = (timelineItems.push(w), timelineItems) %}
    {% endif %}
  {% endfor %}
  {% if timelineItems | length %}
  <section class="td-timeline">
    <h2>Tímalína</h2>
    {# Compute time range: Jan 1 2026 to latest entry + 1 week buffer #}
    {% set yearStartMs = 1767225600000 %}{# 2026-01-01T00:00:00Z #}
    {% set lastWeekMs = 0 %}
    {% set maxSightings = 0 %}
    {% for w in timelineItems %}
      {% set wMs = w.week | isDateToMs %}
      {% if wMs > lastWeekMs %}{% set lastWeekMs = wMs %}{% endif %}
      {% if w.sightings > maxSightings %}{% set maxSightings = w.sightings %}{% endif %}
    {% endfor %}
    {% set rangeEndMs = lastWeekMs + 604800000 %}{# +7 days buffer #}
    {% set rangeMs = rangeEndMs - yearStartMs %}

    {# Determine label thinning: ≤15 all, 16-30 every other, 30+ month-only #}
    {% set barCount = timelineItems | length %}
    {% set thinMode = "all" %}
    {% if barCount > 30 %}{% set thinMode = "month" %}
    {% elif barCount > 15 %}{% set thinMode = "everyOther" %}{% endif %}

    <div class="td-timeline-chart">
      <div class="td-timeline-bars">
        {% for w in timelineItems %}
          {% set wMs = w.week | isDateToMs %}
          {% set leftPct = ((wMs - yearStartMs) / rangeMs * 100) | round(2) %}
          {% set heightPct = (w.sightings / (maxSightings or 1) * 100) | round %}
          <div class="td-timeline-bar" style="left: {{ leftPct }}%" title="{{ w.week | isDate }}: {{ w.sightings }} tilvísanir, {{ w.new_claims }} nýjar fullyrðingar">
            <div class="td-timeline-fill" style="height: {{ heightPct }}%"></div>
          </div>
        {% endfor %}
      </div>

      {# ── Label rows ── #}
      <div class="td-timeline-labels">
        {# Row 1: Day of month #}
        {% for w in timelineItems %}
          {% set wMs = w.week | isDateToMs %}
          {% set leftPct = ((wMs - yearStartMs) / rangeMs * 100) | round(2) %}
          {% set showDay = true %}
          {% if thinMode == "month" %}
            {% set showDay = false %}
          {% elif thinMode == "everyOther" %}
            {% if loop.index0 % 2 != 0 %}{% set showDay = false %}{% endif %}
          {% endif %}
          {% if showDay %}
          <span class="td-label-day" style="left: {{ leftPct }}%">{{ w.week | isDayOfMonth }}</span>
          {% endif %}
        {% endfor %}
      </div>

      <div class="td-timeline-labels td-timeline-labels--month">
        {# Row 2: Month name — only at first bar of each new month #}
        {% set prevMonth = -1 %}
        {% for w in timelineItems %}
          {% set wMs = w.week | isDateToMs %}
          {% set leftPct = ((wMs - yearStartMs) / rangeMs * 100) | round(2) %}
          {% set curMonth = w.week | isMonth1 %}
          {% if curMonth != prevMonth %}
          <span class="td-label-month" style="left: {{ leftPct }}%">{{ w.week | isMonthShort }}</span>
          {% set prevMonth = curMonth %}
          {% endif %}
        {% endfor %}
      </div>

      <div class="td-timeline-labels td-timeline-labels--year">
        {# Row 3: Year — shown once at left edge (all data is 2026) #}
        <span class="td-label-year" style="left: 0%">2026</span>
      </div>
    </div>
  </section>
  {% endif %}

  {# ── Claims (embedded tracker) ── #}
  <section class="td-claims" id="topic-claim-tracker"
           data-category="{{ topic.slug }}"
           data-base="/assets/data">
    <h2>Fullyrðingar ({{ topic.claims | length }})</h2>
    <noscript>
      <p>Kveiktu á JavaScript til að skoða fullyrðingar.</p>
    </noscript>
  </section>

  {# ── Evidence ── #}
  {% if topic.evidence | length %}
  <section class="td-evidence">
    <h2>Heimildir ({{ topic.evidence | length }})</h2>

    <div class="td-evidence-grid">
      {% for ev in topic.evidence %}
      <a href="/heimildir/{{ ev.evidence_id | lower | replace("_", "-") }}/" class="td-evidence-card">
        <span class="td-evidence-id">{{ ev.evidence_id }}</span>
        <p class="td-evidence-statement">{{ ev.statement_is or ev.statement }}</p>
        <span class="td-evidence-source">{{ ev.source_name }}</span>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── Entities ── #}
  {% if topic.entities | length %}
  <section class="td-entities">
    <h2>Aðilar</h2>

    <div class="td-entity-grid">
      {% for ent in topic.entities %}
      <a href="/raddirnar/{{ ent.slug }}/" class="td-entity-card">
        <h3 class="td-entity-name">{{ ent.name }}</h3>
        <span class="td-entity-claims">{{ ent.claim_count }} fullyrðing{{ "ar" if ent.claim_count > 1 else "" }}</span>
        {% if ent.verdict_breakdown %}
        <div class="td-entity-verdicts">
          {% for v in verdictOrder %}
            {% if ent.verdict_breakdown[v] %}
            <span class="ct-verdict-pill verdict-{{ v | replace("partially_supported", "partial") }}" title="{{ v | verdictDescription }}">
              {{ v | verdictLabel }}: {{ ent.verdict_breakdown[v] }}
            </span>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ── Source breakdown ── #}
  {% if topic.source_activity | length %}
  <section class="td-sources">
    <h2>Fjölmiðlar</h2>
    <table class="td-source-table">
      <thead>
        <tr>
          <th>Miðill</th>
          <th>Greinar</th>
          <th>Fullyrðingar</th>
        </tr>
      </thead>
      <tbody>
        {% for src in topic.source_activity %}
        <tr>
          <td>{{ src.source }}</td>
          <td>{{ src.articles }}</td>
          <td>{{ src.claims }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}
</article>
