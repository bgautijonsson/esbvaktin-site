---
layout: base.njk
title: ESB Vaktin
description: Óháð, gagnadrifið upplýsingaverkefni um ESB-þjóðaratkvæðagreiðsluna 29. ágúst 2026.
wide_layout: true
---

{# ── Hero: What is ESB Vaktin? ── #}
<section class="home-hero">
  <div class="home-hero-copy">
    <h1>Þjóðaratkvæðagreiðslan um ESB nálgast.</h1>
    <p class="home-deck">ESB Vaktin er óháð upplýsingaverkefni sem fylgist með fullyrðingum í umræðunni um ESB-aðild Íslands &mdash; metur þær á móti gögnum og birtir niðurstöður.</p>
    <div class="home-hero-meta-strip">
      <span><strong>{{ site.referendum_date | isDate }}</strong> kjördagur</span>
      <span><strong>{{ home.days_until_referendum | localeString }} dagar</strong> eftir</span>
      <span><strong>{{ home.last_updated | isDate }}</strong> síðasta uppfærsla</span>
    </div>
  </div>
</section>

{# ── Pipeline: How ESB Vaktin works ── #}
<section class="home-pipeline" aria-labelledby="pipeline-heading">
  <h2 class="home-pipeline-heading" id="pipeline-heading">Hvernig ESB Vaktin vinnur</h2>
  <div class="home-pipeline-steps">
    <a href="/umraedan/" class="home-pipeline-step">
      <span class="home-pipeline-icon" aria-hidden="true">1</span>
      <span class="home-pipeline-label">Umræða</span>
      <span class="home-pipeline-desc">Greinar, ræður og viðtöl skoðuð</span>
      <span class="home-pipeline-count">{{ home.signal_stats[1].value | localeString }} greinar</span>
    </a>
    <span class="home-pipeline-arrow" aria-hidden="true"></span>
    <a href="/fullyrdingar/" class="home-pipeline-step">
      <span class="home-pipeline-icon" aria-hidden="true">2</span>
      <span class="home-pipeline-label">Fullyrðingar</span>
      <span class="home-pipeline-desc">Mælanlegar staðhæfingar dregnar út</span>
      <span class="home-pipeline-count">{{ home.signal_stats[0].value | localeString }} skráðar</span>
    </a>
    <span class="home-pipeline-arrow" aria-hidden="true"></span>
    <a href="/heimildir/" class="home-pipeline-step">
      <span class="home-pipeline-icon" aria-hidden="true">3</span>
      <span class="home-pipeline-label">Heimildir</span>
      <span class="home-pipeline-desc">Bornar saman við gögn og lagaákvæði</span>
      <span class="home-pipeline-count">{{ home.signal_stats[3].value | localeString }} heimildir</span>
    </a>
    <span class="home-pipeline-arrow" aria-hidden="true"></span>
    <div class="home-pipeline-step home-pipeline-step--final">
      <span class="home-pipeline-icon" aria-hidden="true">4</span>
      <span class="home-pipeline-label">Mat</span>
      <span class="home-pipeline-desc">Fullyrðingar flokkaðar eftir trúverðugleika</span>
      <span class="home-pipeline-verdicts">
        <span class="home-verdict-dot home-verdict-dot--supported" title="Staðfest"></span>
        <span class="home-verdict-dot home-verdict-dot--partial" title="Að hluta staðfest"></span>
        <span class="home-verdict-dot home-verdict-dot--unverifiable" title="Ósannanlegt"></span>
        <span class="home-verdict-dot home-verdict-dot--unsupported" title="Óstutt"></span>
        <span class="home-verdict-dot home-verdict-dot--misleading" title="Villandi"></span>
      </span>
    </div>
  </div>
</section>

{# ── Main content grid ── #}
<div class="home-grid">
  <div class="home-main">

    {# ── Weekly review ── #}
    {% if home.weekly_review %}
    <section class="home-section home-weekly" aria-labelledby="home-weekly-heading">
      <div class="home-section-head">
        <div>
          <p class="home-section-label">Vikuyfirlit</p>
          <h2 id="home-weekly-heading">Vikan {{ home.weekly_review.period_start | isDateRange(home.weekly_review.period_end) }}</h2>
        </div>
        <a href="/vikuyfirlit/{{ home.weekly_review.slug }}/" class="home-text-link">Allt yfirlitið</a>
      </div>

      <div class="home-weekly-summary">
        <div class="home-weekly-numbers">
          <span><strong>{{ home.weekly_review.articles_analysed }}</strong> greinar greindar</span>
          <span><strong>{{ home.weekly_review.new_claims | localeString }}</strong> fullyrðingar birtar</span>
        </div>
        {% if home.weekly_review.verdict_breakdown %}
        <div class="home-weekly-bar-wrap">
          {% set vb = home.weekly_review.verdict_breakdown %}
          {% set vtotal = (vb.supported or 0) + (vb.partially_supported or 0) + (vb.unverifiable or 0) + (vb.unsupported or 0) + (vb.misleading or 0) %}
          {% if vtotal > 0 %}
          <div class="home-weekly-bar" role="img" aria-label="Dreifing niðurstaðna vikunnar">
            {% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
            {% for v in verdictOrder %}
              {% set count = vb[v] or 0 %}
              {% if count %}
                {% set pct = (count / vtotal * 100) | round(1) %}
                <span class="home-bar-seg home-verdict-bg--{{ v | replace("partially_supported", "partial") }}"
                      style="width:{{ pct }}%"
                      title="{{ v | verdictLabel }}: {{ count }}"></span>
              {% endif %}
            {% endfor %}
          </div>
          <div class="home-weekly-legend">
            {% for v in verdictOrder %}
              {% set count = vb[v] or 0 %}
              {% if count %}
              <span class="home-legend-item">
                <span class="home-verdict-dot home-verdict-dot--{{ v | replace("partially_supported", "partial") }}"></span>
                {{ v | verdictLabel }} <strong>{{ count }}</strong>
              </span>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% endif %}
      </div>

      {% if home.weekly_review.editorial_lead %}
      <div class="home-weekly-editorial">
        {% for para in home.weekly_review.editorial_lead.split("\n\n") %}
          {% if para | trim %}<p>{{ para | trim }}</p>{% endif %}
        {% endfor %}
      </div>
      {% endif %}

    </section>
    {% endif %}

    {# ── Topics overview ── #}
    {% if home.top_topics | length %}
    <section class="home-section" aria-labelledby="home-topics-heading">
      <div class="home-section-head">
        <div>
          <p class="home-section-label">Málefni</p>
          <h2 id="home-topics-heading">Virkustu málin</h2>
        </div>
        <a href="/malefni/" class="home-text-link">Öll málefni</a>
      </div>
      <div class="home-topic-bar">
        {% for topic in home.top_topics %}
        <a href="/malefni/{{ topic.slug }}/" class="home-topic-card">
          <span class="home-section-label">{{ topic.label_is }}</span>
          <span class="home-signal-value">{{ topic.published_claim_count | localeString }}</span>
          <span class="home-signal-note">fullyrðingar</span>
          {% if topic.verdict_counts %}
          <div class="home-topic-verdicts">
            {% set verdictOrder = ["supported", "partially_supported", "unverifiable", "unsupported", "misleading"] %}
            {% set vtotal = 0 %}
            {% for v in verdictOrder %}{% set vtotal = vtotal + (topic.verdict_counts[v] or 0) %}{% endfor %}
            {% if vtotal > 0 %}
            <div class="report-verdict-bar home-topic-verdict-bar" role="img" aria-label="Dreifing niðurstaðna">
              {% for v in verdictOrder %}
                {% set count = topic.verdict_counts[v] or 0 %}
                {% if count %}
                  {% set pct = (count / vtotal * 100) | round(1) %}
                  <span class="report-bar-seg home-verdict-bg--{{ v | replace("partially_supported", "partial") }}"
                        style="width:{{ pct }}%"
                        title="{{ v | verdictLabel }}: {{ count }}"></span>
                {% endif %}
              {% endfor %}
            </div>
            {% endif %}
          </div>
          {% endif %}
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}
  </div>

  {# ── Sidebar ── #}
  <aside class="home-sidebar" aria-label="Yfirlit af forsíðu">
    {# ── Data stats (compact) ── #}
    <section class="home-sidebar-section home-stats-compact">
      <div class="home-section-head home-section-head-compact">
        <div>
          <p class="home-section-label">Gagnasöfn</p>
          <h2>Í safninu</h2>
        </div>
      </div>
      <div class="home-stats-list">
        {% for stat in home.signal_stats %}
        <a href="{{ stat.href }}" class="home-stat-row">
          <span class="home-stat-label">{{ stat.label }}</span>
          <span class="home-stat-value">{{ stat.value | localeString }}</span>
        </a>
        {% endfor %}
      </div>
    </section>

    <section class="home-sidebar-section">
      <div class="home-section-head home-section-head-compact">
        <div>
          <p class="home-section-label">Raddir í fókus</p>
          <h2>Oftast nefnd</h2>
        </div>
      </div>
      <div class="home-sidebar-list">
        {% for entity in home.top_entities %}
        <a href="/raddirnar/{{ entity.slug }}/" class="home-sidebar-item home-sidebar-item--entity home-sidebar-link">
          <div class="home-sidebar-meta">
            <span>{{ entity.type | entityTypeLabel }}</span>
            {% if entity.party %}<span>{{ entity.party }}</span>{% endif %}
          </div>
          <h3>{{ entity.name }}</h3>
          <div class="home-sidebar-stats">
            <span>{{ entity.mention_count | localeString }} tilvísanir</span>
            <span>{{ entity.claim_count | localeString }} fullyrðingar</span>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>

    <section class="home-sidebar-section">
      <div class="home-section-head home-section-head-compact">
        <div>
          <p class="home-section-label">Nýtt í safninu</p>
          <h2>Nýjustu greiningar</h2>
        </div>
      </div>
      <div class="home-sidebar-list">
        {% for report in home.processed_reports %}
        <a href="/umraedan/{{ report.slug }}/" class="home-sidebar-item home-sidebar-item--article home-sidebar-link">
          <div class="home-sidebar-meta">
            <span>{{ report.article_source }}</span>
            <span>{{ report.display_date | isDate }}</span>
          </div>
          <h3>{{ report.article_title }}</h3>
          <div class="home-sidebar-stats">
            <span>{{ report.claim_count | localeString }} fullyrðingar</span>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>

    {# ── Support the project ── #}
    <section class="home-sidebar-section home-support" aria-labelledby="home-support-heading">
      <div class="home-section-head home-section-head-compact">
        <div>
          <p class="home-section-label">Stuðningur</p>
          <h2 id="home-support-heading">Styrkja verkefnið</h2>
        </div>
      </div>
      <p class="home-support-desc">ESB Vaktin er rekin án áskrifta og auglýsinga. Framlög fara í rekstur vefsíðu og gagnavinnslu.</p>
      <div class="home-support-buttons">
        <button type="button" class="home-support-btn" onclick="document.querySelector('#bmc-wbtn')?.click()">
          Styrkja verkefnið
        </button>
      </div>
    </section>
  </aside>
</div>
