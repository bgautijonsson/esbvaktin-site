---
layout: base.njk
title: ESBvaktin
description: Óháð, gagnadrifið upplýsingaverkefni um ESB-þjóðaratkvæðagreiðsluna 29. ágúst 2026.
wide_layout: true
---

<div class="home-grid">
  <div class="home-main">
    <section class="home-hero">
      <div class="home-hero-copy">
        <p class="home-kicker">ESB-umræðan í gögnum</p>
        <h1>Gögn um ESB-umræðuna á einum stað.</h1>
        <p class="home-deck">ESBvaktin heldur utan um fullyrðingar, greiningar, heimildir, raddir og þingræður svo umræðan sé lesin sem safn gagna fremur en kynningarefni.</p>
        <div class="home-hero-meta-strip">
          <span><strong>{{ home.last_updated | isDate }}</strong> síðasta uppfærsla</span>
          <span><strong>{{ site.referendum_date | isDate }}</strong> kjördagur</span>
          <span><strong>{{ home.days_until_referendum | localeString }} dagar</strong> til þjóðaratkvæðis</span>
        </div>
        <div class="home-hero-actions">
          <a href="/fullyrdingar/" class="home-cta">Opna fullyrðingar</a>
          <a href="/umraedan/" class="home-cta home-cta-secondary">Skoða umræðuna</a>
        </div>
      </div>
    </section>

    <section class="home-section" aria-labelledby="home-core-heading">
      <div class="home-section-head">
        <div>
          <p class="home-section-label">Gagnasöfn</p>
          <h2 id="home-core-heading">Beint í gögnin</h2>
        </div>
      </div>
      <div class="home-signal-bar">
        {% for stat in home.signal_stats %}
        <a href="{{ stat.href }}" class="home-signal-card">
          <span class="home-section-label">{{ stat.label }}</span>
          <span class="home-signal-value">{{ stat.value | localeString }}</span>
          <span class="home-signal-note">{{ stat.note }}</span>
        </a>
        {% endfor %}
      </div>
    </section>
  </div>

  <aside class="home-sidebar" aria-label="Yfirlit af forsíðu">
    <section class="home-sidebar-section">
      <div class="home-section-head home-section-head-compact">
        <div>
          <p class="home-section-label">Raddir í fókus</p>
          <h2>Oftast nefnd</h2>
        </div>
        <a href="/raddirnar/" class="home-text-link">Allar raddir</a>
      </div>
      <div class="home-sidebar-list">
        {% for entity in home.top_entities %}
        <article class="home-sidebar-item home-sidebar-item--entity">
          <div class="home-sidebar-meta">
            <span>{{ entity.type | entityTypeLabel }}</span>
            {% if entity.party %}<span>{{ entity.party }}</span>{% endif %}
          </div>
          <h3><a href="/raddirnar/{{ entity.slug }}/">{{ entity.name }}</a></h3>
          <div class="home-sidebar-stats">
            <span>{{ entity.mention_count | localeString }} tilvísanir</span>
            <span>{{ entity.claim_count | localeString }} fullyrðingar</span>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="home-sidebar-section">
      <div class="home-section-head home-section-head-compact">
        <div>
          <p class="home-section-label">Nýtt í safninu</p>
          <h2>Nýjustu greiningar</h2>
        </div>
        <a href="/umraedan/" class="home-text-link">Allar greiningar</a>
      </div>
      <div class="home-sidebar-list">
        {% for report in home.processed_reports %}
        <article class="home-sidebar-item home-sidebar-item--article">
          <div class="home-sidebar-meta">
            <span>{{ report.article_source }}</span>
            <span>{{ report.display_date | isDate }}</span>
          </div>
          <h3><a href="/umraedan/{{ report.slug }}/">{{ report.article_title }}</a></h3>
          <div class="home-sidebar-stats">
            {% if report.primary_verdict %}
            <span class="ct-verdict-pill {{ report.primary_verdict_class }}">{{ report.primary_verdict | verdictLabel }}</span>
            {% endif %}
            <span>{{ report.claim_count | localeString }} fullyrðingar</span>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
  </aside>
</div>
