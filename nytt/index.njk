---
layout: base.njk
title: Hvað er nýtt
description: Nýjustu breytingar í ESB-umræðunni — nýjar greiningar, fullyrðingar, og málefni í brennidepli.
wide_layout: true
extra_css: /assets/css/nytt.css
---

<section class="nytt-hero">
  <h1 class="nytt-heading">Hvað er nýtt</h1>
</section>

{# ── Anchor slab — counts updated client-side for "since last visit" ── #}
<div class="nytt-anchor" aria-live="polite" id="nytt-anchor">
  <div class="nytt-anchor-counts" id="nytt-counts">
    {% if nytt.counts.reports %}<span class="nytt-anchor-stat"><strong>{{ nytt.counts.reports }}</strong> {{ "ný greining" if nytt.counts.reports == 1 else "nýjar greiningar" }}</span>{% endif %}
    {% if nytt.counts.claims %}<span class="nytt-anchor-stat"><strong>{{ nytt.counts.claims }}</strong> {{ "ný fullyrðing" if nytt.counts.claims == 1 else "nýjar fullyrðingar" }}</span>{% endif %}
    {% if nytt.counts.spiking %}<span class="nytt-anchor-stat"><strong>{{ nytt.counts.spiking }}</strong> {{ "málefni" if nytt.counts.spiking == 1 else "málefni" }} í brennidepli</span>{% endif %}
    {% if nytt.counts.resurfaced %}<span class="nytt-anchor-stat"><strong>{{ nytt.counts.resurfaced }}</strong> {{ "endurvakin fullyrðing" if nytt.counts.resurfaced == 1 else "endurvaknar fullyrðingar" }}</span>{% endif %}
  </div>
  <p class="nytt-anchor-since" id="nytt-since">Síðustu 7 daga</p>
</div>

{# ── Main content grid ── #}
<div class="nytt-grid">
  <div class="nytt-main">
    {# ── Timeline feed ── #}
    <ol class="nytt-timeline" role="feed" aria-label="Tímalína breytinga" id="nytt-timeline">
      {% for group in nytt.grouped %}
      <li class="nytt-date-group" data-date="{{ group.date }}">
        <h2 class="nytt-date-header">{{ group.date | isDate }}</h2>
        <ol class="nytt-date-items">
          {% for item in group.items %}
          <li class="nytt-item nytt-item--{{ item.type }}">
            <span class="nytt-type-label">{{ item.typeLabel }}</span>
            {% if item.type == "brennidepill" %}
            <h3 class="nytt-item-title">
              <a href="{{ item.href }}">
                <span class="nytt-spike-badge">{{ item.title }}</span>
              </a>
            </h3>
            {% else %}
            <h3 class="nytt-item-title"><a href="{{ item.href }}">{{ item.title }}</a></h3>
            {% endif %}
            <div class="nytt-item-meta">
              {% if item.verdict %}
              <span class="nytt-verdict nytt-verdict--{{ item.verdict | replace("partially_supported", "partial") }}" aria-label="{{ item.verdictLabel }}">{{ item.verdictLabel }}</span>
              {% endif %}
              {% if item.categoryLabel and item.type == "greining" %}
              <span>{{ item.categoryLabel }}</span>
              {% endif %}
              <span>{{ item.meta }}</span>
            </div>
          </li>
          {% endfor %}
        </ol>
      </li>
      {% endfor %}
    </ol>

    {# ── Empty / caught-up states (hidden by default, shown via JS) ── #}
    <div class="nytt-empty" id="nytt-empty" hidden>
      <p>Ekkert nýtt síðustu 7 daga. <a href="/vikuyfirlit/">Vikuyfirlitið &rarr;</a></p>
    </div>
    <div class="nytt-caught-up" id="nytt-caught-up" hidden>
      <p>&check; Þú ert í takt. Nýtt vikuyfirlit birtist á mánudegi.</p>
    </div>
  </div>

  {# ── Sidebar: Topic pulse ── #}
  <aside class="nytt-sidebar" aria-label="Málefni í brennidepli">
    <div class="nytt-sidebar-section">
      <p class="nytt-sidebar-label">Málefni</p>
      <h2 class="nytt-sidebar-heading">Virkasta vikunnar</h2>
    </div>
    {% set topicsSorted = nytt.items | selectattr("type", "equalto", "brennidepill") %}
    {% for topic in nytt.items %}
    {% if topic.type == "brennidepill" %}
    <a href="{{ topic.href }}" class="nytt-sidebar-topic">
      <span class="nytt-spike-badge">{{ topic.title }}</span>
      <span class="nytt-sidebar-topic-meta">{{ topic.meta }}</span>
    </a>
    {% endif %}
    {% endfor %}

    <div class="nytt-sidebar-section" style="margin-top: var(--sp-xl)">
      <p class="nytt-sidebar-label">Endurvakin</p>
      <h2 class="nytt-sidebar-heading">Aftur í umræðunni</h2>
    </div>
    {% set resurfacedCount = 0 %}
    {% for item in nytt.items %}
    {% if item.type == "endurvakin" and resurfacedCount < 5 %}
    {% set resurfacedCount = resurfacedCount + 1 %}
    <a href="{{ item.href }}" class="nytt-sidebar-resurfaced">
      <span class="nytt-sidebar-resurfaced-title">{{ item.title | truncate(80) }}</span>
      <span class="nytt-sidebar-topic-meta">{{ item.gapDays }} daga hlé</span>
    </a>
    {% endif %}
    {% endfor %}
  </aside>
</div>

<script src="/assets/js/nytt-client.js" defer></script>
