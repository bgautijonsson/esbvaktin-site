{
  "name": "esbvaktin-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static site for esbvaktin.is",
  "scripts": {
    "build": "npm run clean && eleventy && bash tools/minify.sh",
    "serve": "eleventy --serve",
    "clean": "rm -rf _site",
    "browser:test": "playwright test",
    "browser:review": "playwright test tests/browser",
    "browser:smoke": "playwright test tests/browser/smoke.spec.js",
    "browser:screens": "playwright test tests/browser/screenshots.spec.js",
    "browser:nav": "playwright test tests/browser/navbar.spec.js",
    "stats": "node tools/stats.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@playwright/test": "^1.58.2",
    "clean-css-cli": "^5.6.3",
    "terser": "^5.46.1"
  }
}
